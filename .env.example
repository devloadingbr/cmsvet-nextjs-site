# CSM Clínica Veterinária - Environment Variables Template
# Copy this file to .env.local and fill with your actual values

# ========================
# CLINIC INFORMATION
# ========================
NEXT_PUBLIC_CLINIC_NAME="CSM Clínica Veterinária"
NEXT_PUBLIC_PHONE_PRIMARY="(41) 3077-0023"
NEXT_PUBLIC_WHATSAPP="554130770023"
NEXT_PUBLIC_EMAIL="contato@csmclinicaveterinaria.com.br"

# ========================
# ADDRESS & LOCATION
# ========================
NEXT_PUBLIC_ADDRESS_STREET="Rua Julio Wischral, 1099"
NEXT_PUBLIC_ADDRESS_NEIGHBORHOOD="Uberaba"
NEXT_PUBLIC_ADDRESS_CITY="Curitiba"
NEXT_PUBLIC_ADDRESS_STATE="PR"
NEXT_PUBLIC_ADDRESS_CEP="82520-000"
NEXT_PUBLIC_ADDRESS_FULL="Rua Julio Wischral, 1099 - Uberaba, Curitiba/PR"

# ========================
# BUSINESS HOURS
# ========================
NEXT_PUBLIC_HOURS_WEEKDAYS="24 horas"
NEXT_PUBLIC_HOURS_WEEKEND="24 horas"
NEXT_PUBLIC_EMERGENCY_AVAILABLE="true"

# ========================
# STATISTICS
# ========================
NEXT_PUBLIC_STATS_PETS_CARED="15000"
NEXT_PUBLIC_STATS_YEARS_EXPERIENCE="7"
NEXT_PUBLIC_STATS_RATING="4.8"
NEXT_PUBLIC_STATS_TEAM_SIZE="3"

# ========================
# SOCIAL MEDIA
# ========================
NEXT_PUBLIC_INSTAGRAM="@csmvet"
NEXT_PUBLIC_FACEBOOK="csmvet"
NEXT_PUBLIC_GOOGLE_MAPS_URL="https://maps.google.com/?q=CSM+Clinica+Veterinaria+Curitiba"

# ========================
# SEO
# ========================
NEXT_PUBLIC_SITE_URL="https://csmclinicaveterinaria.com.br"
NEXT_PUBLIC_SITE_NAME="CSM Clínica Veterinária"
NEXT_PUBLIC_SITE_DESCRIPTION="Clínica veterinária 24h em Curitiba. Atendimento de emergência, consultas, cirurgias e cuidados especializados para seu pet."

# ========================
# TRACKING & ANALYTICS
# Deixe comentado para desativar. Só carrega se a var estiver preenchida.
# ========================

# Google Tag Manager — container central de tags (recomendado)
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Google Analytics 4 — analytics standalone (se não usar GA via GTM)
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Meta/Facebook Pixel — remarketing e conversões Facebook/Instagram
# NEXT_PUBLIC_FACEBOOK_PIXEL_ID="123456789012345"

# Microsoft Clarity — heatmaps e gravações de sessão (gratuito)
# NEXT_PUBLIC_CLARITY_ID="abc123xyz"

# ========================
# VERIFICAÇÃO DE DOMÍNIO
# ========================

# Google Search Console — verificação de propriedade
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="abc123..."

# Facebook Business — verificação de domínio
# NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION="abc123..."

# ========================
# API KEYS (PRIVATE)
# ========================
# GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
# SENDGRID_API_KEY="your-sendgrid-api-key"